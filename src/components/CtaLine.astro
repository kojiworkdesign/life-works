---
interface Props {
  title?: string;
  desc?: string;
}
const {
  title = 'LINE登録で、無料ツールの「詳しい設計版」を開放しています',
  desc = '「家計と投資の健康診断」で、目的別に必要な積立額まで出せる詳細版のパスワードを、無料でお渡ししています。登録は無料で、いつでも解除できます。',
} = Astro.props;
---

<div class="cta cta-line">
  <p class="cta-title">{title}</p>
  <p class="cta-desc">{desc}</p>
  <a class="cta-btn" href="https://lin.ee/xUvz1le" target="_blank" rel="noopener">
    LINEで受け取る →
  </a>
</div>
