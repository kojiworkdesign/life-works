---
// kyoiku-hi/index.html から自動移行。本文・スクリプトは原文のまま。
import Base from '../../layouts/Base.astro';
import '../../styles/tools/kyoiku-hi.css';
---

<Base
  title="教育費シミュレーター | らくらく夫婦ツール"
  description="子どもの年齢・進路から教育費の総額と必要な積立額を計算します。幼稚園から大学まで、ステージごとに細かく設定できます。"
  ogImage="/images/card-kyoiku-hi.png"
>
<header class="header">
    <div class="header-inner">
      <a href="/" class="logo">らくらく夫婦<span>ツール</span></a>
    </div>
  </header>

  <div class="tool-wrap">

    <a href="/" class="back-link">← ツール一覧へ</a>

    <div class="tool-header">
      <p class="tool-eyebrow">家計・資産形成</p>
      <h1 class="tool-title">教育費<br>シミュレーター</h1>
      <p class="tool-desc">子どもの年齢・進路から教育費の総額と必要な積立額を計算します。<br>幼稚園から大学まで、ステージごとに細かく設定できます。</p>
    </div>

    <!-- STEP 1 -->
    <div class="form-card">
      <p class="step-label">STEP 1 ／ 子どもの情報</p>

      <div class="form-group">
        <label>子どもの人数</label>
        <div class="btn-group" id="num-children-group">
          <button class="btn-opt selected" onclick="setNumChildren(1)">1人</button>
          <button class="btn-opt" onclick="setNumChildren(2)">2人</button>
          <button class="btn-opt" onclick="setNumChildren(3)">3人</button>
          <button class="btn-opt" onclick="setNumChildren(4)">4人</button>
        </div>
      </div>

      <div id="age-inputs-wrap"></div>
    </div>

    <!-- STEP 2 -->
    <div class="form-card">
      <p class="step-label">STEP 2 ／ 進路設定</p>
      <p class="step-note">子どもごとにタブを切り替えて、各ステージの学校・塾を設定してください。</p>

      <div class="child-tab-header" id="child-tab-header"></div>
      <div id="child-tab-panels"></div>
    </div>

    <!-- STEP 3 -->
    <div class="form-card">
      <p class="step-label">STEP 3 ／ 現在の教育資金状況</p>

      <div class="form-group">
        <label>現在の教育資金残高<span class="label-note">学資保険・積立NISA・預金など合計</span></label>
        <div class="input-with-unit">
          <input type="number" id="current-balance" placeholder="0" min="0">
          <span class="unit">万円</span>
        </div>
      </div>

      <div class="form-group">
        <label>月々の積立額<span class="label-note">現在の教育費向け積立</span></label>
        <div class="input-with-unit">
          <input type="number" id="monthly-saving" placeholder="3" min="0">
          <span class="unit">万円</span>
        </div>
      </div>

      <div class="form-group">
        <label>積立スタイル（想定年利回り）</label>
        <div class="select-wrap">
          <select id="return-rate">
            <option value="0">0%：現金のみ（銀行預金・タンス預金）</option>
            <option value="1">1%：定期預金・個人向け国債</option>
            <option value="2">2%：債券重視（債券90%・株式10%程度）</option>
            <option value="3" selected>3%：債券中心（債券70%・株式30%程度）</option>
            <option value="4">4%：バランス型（債券50%・株式50%程度）</option>
            <option value="5">5%：株式重視（株式70%・債券30%程度）</option>
          </select>
        </div>
      </div>
    </div>

    <button class="btn-calc" onclick="calculate()">教育費を計算する</button>

    <!-- 結果エリア -->
    <div class="result-area" id="result-area">

      <p class="result-section-label">教育費シミュレーション結果</p>

      <div class="result-total-card">
        <p class="metric-total-label">教育費の総額（全子ども合計）</p>
        <div class="metric-total-value" id="result-total-cost">—<span>万円</span></div>
      </div>

      <div class="breakdown-card">
        <p class="breakdown-card-title">内訳（子どもごと・ステージ別）</p>
        <div id="result-breakdown"></div>
      </div>

      <div class="chart-card">
        <p class="chart-card-title">年ごとの教育費支出の推移</p>
        <canvas id="expense-chart"></canvas>
      </div>

      <p class="result-section-label">積立シミュレーション結果</p>

      <div class="schedule-card">
        <p class="schedule-card-title">必要な積立額（期間ごと）</p>
        <div id="result-schedule"></div>
      </div>

      <div class="chart-card">
        <p class="chart-card-title">教育資金残高の推移（現在の積立額の場合）</p>
        <canvas id="balance-chart"></canvas>
      </div>

      <div class="prescription-card">
        <p class="prescription-from">らくらく夫婦よりアドバイス</p>
        <p class="prescription-text" id="prescription-text"></p>
      </div>

      <a class="share-btn" id="share-btn" href="#" target="_blank">
        𝕏 結果をポストする
      </a>

      <div class="brand-cta-section">
        <div class="brand-cta-header">
          <img src="/images/icon.png" alt="らくらく夫婦" class="brand-icon">
          <div>
            <p class="brand-cta-lead">らくらく夫婦と一緒に</p>
            <p class="brand-cta-title">お金の仕組みを、<br>夫婦でつくっていきませんか？</p>
          </div>
        </div>
        <p class="brand-cta-body">家計管理・資産形成のコツをLINEとnoteで発信中。まずは無料テンプレをLINEで受け取ってみてください。</p>
        <a href="https://lin.ee/Yzw8sE4" target="_blank" class="line-banner-link">
          <img src="/images/banner-line.png" alt="LINEで家計レントゲンシートを今すぐ受け取る">
        </a>
        <div class="cta-note">
          <div class="cta-note-text">
            <p class="cta-note-title">教育費の積立設計の考え方</p>
            <p class="cta-note-desc">いつまでにいくら必要か、noteで解説しています。</p>
          </div>
          <a href="https://note.com/rakufu_log" target="_blank" class="btn-cta">読む →</a>
        </div>
      </div>

      <div class="affiliate-banner">
        <p class="affiliate-label">PR</p>
        <a href="https://px.a8.net/svt/ejp?a8mat=4B3R30+4M3YK2+3XCC+669JL" rel="nofollow">
          <img border="0" width="468" height="60" alt="松井証券" src="https://www27.a8.net/svt/bgt?aid=260515548279&wid=001&eno=01&mid=s00000018318001037000&mc=1">
        </a>
        <img border="0" width="1" height="1" src="https://www17.a8.net/0.gif?a8mat=4B3R30+4M3YK2+3XCC+669JL" alt="">
      </div>

    </div>

  </div>

  <footer class="footer">
    <p>© 2026 <a href="https://note.com/rakufu_log" target="_blank">らくらく夫婦</a> ｜ <a href="/">ツール一覧</a></p>
  </footer>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <script is:inline>
    // ── 定数 ──────────────────────────────────────────
    const STAGES = [
      {
        id: 'kindergarten', name: '幼稚園', years: 3, deadlineAge: 3,
        costs: { public: 16.5, private: 31.0 },
        examLabel: '小学校受験の準備',
        examCosts: { none: 0, standard: 30, full: 80 }
      },
      {
        id: 'elementary', name: '小学校', years: 6, deadlineAge: 6,
        costs: { public: 35.2, private: 166.9 },
        examLabel: '中学受験の準備',
        examCosts: { none: 0, standard: 80, full: 200 }
      },
      {
        id: 'middle', name: '中学校', years: 3, deadlineAge: 12,
        costs: { public: 53.8, private: 143.6 },
        examLabel: '高校受験の準備',
        examCosts: { none: 0, standard: 45, full: 90 }
      },
      {
        id: 'highschool', name: '高校', years: 3, deadlineAge: 15,
        costs: { public: 51.3, private: 105.4 },
        examLabel: '大学受験の準備',
        examCosts: { none: 0, standard: 75, full: 120 }
      },
      {
        id: 'university', name: '大学・専門', deadlineAge: 18,
        options: {
          national:   { label: '国公立',    annual: 53.6,  entrance: 28.2, years: 4 },
          liberal:    { label: '私立文系',  annual: 93.9,  entrance: 22.0, years: 4 },
          science:    { label: '私立理系',  annual: 122.9, entrance: 24.0, years: 4 },
          vocational: { label: '専門・短大', annual: 82.0, entrance: 20.0, years: 2 },
          skip:       { label: '進学しない', annual: 0,    entrance: 0,    years: 0 }
        }
      }
    ];

    const CHILD_COLORS = ['#5B7C5F', '#E8B84B', '#7BA7BC', '#C27B7B'];

    // ── 状態 ──────────────────────────────────────────
    let numChildren = 1;
    let childAges = [null];
    let childSettings = [defaultSettings()];
    let activeChildTab = 0;
    let expenseChart = null;
    let balanceChart = null;

    function defaultSettings() {
      return [
        { school: 'public', exam: 'none' },
        { school: 'public', exam: 'none' },
        { school: 'public', exam: 'none' },
        { school: 'public', exam: 'none' },
        { school: 'national' }
      ];
    }

    // ── STEP 1 ────────────────────────────────────────
    function setNumChildren(n) {
      numChildren = n;
      document.querySelectorAll('#num-children-group .btn-opt').forEach((btn, i) => {
        btn.classList.toggle('selected', i + 1 === n);
      });
      while (childAges.length < n) { childAges.push(null); }
      while (childSettings.length < n) { childSettings.push(defaultSettings()); }
      renderAgeInputs();
      if (activeChildTab >= n) activeChildTab = n - 1;
      renderChildTabs();
    }

    function renderAgeInputs() {
      const wrap = document.getElementById('age-inputs-wrap');
      let html = '';
      for (let i = 0; i < numChildren; i++) {
        const val = childAges[i] !== null ? childAges[i] : '';
        html += `
          <div class="form-group" style="margin-top:18px;">
            <label>子ども${i + 1}の現在年齢</label>
            <div class="input-with-unit">
              <input type="number" id="age-input-${i}" placeholder="0" min="0" max="17"
                value="${val}" oninput="onAgeChange(${i}, this.value)">
              <span class="unit">歳</span>
            </div>
          </div>`;
      }
      wrap.innerHTML = html;
    }

    function onAgeChange(childIndex, value) {
      childAges[childIndex] = value !== '' ? parseInt(value) : null;
      const btn = document.querySelector(`[data-ctab="${childIndex}"]`);
      if (btn) btn.textContent = childTabLabel(childIndex);
      renderChildPanel(childIndex);
    }

    function childTabLabel(i) {
      const age = childAges[i];
      return `子ども${i + 1}${age !== null ? `（${age}歳）` : ''}`;
    }

    // ── STEP 2 ────────────────────────────────────────
    function renderChildTabs() {
      const header = document.getElementById('child-tab-header');
      const panels = document.getElementById('child-tab-panels');

      let hHtml = '', pHtml = '';
      for (let i = 0; i < numChildren; i++) {
        hHtml += `<button class="child-tab-btn ${i === activeChildTab ? 'active' : ''}"
          data-ctab="${i}" onclick="switchChildTab(${i})">${childTabLabel(i)}</button>`;
        pHtml += `<div id="child-panel-${i}" class="child-panel ${i === activeChildTab ? 'active' : ''}"></div>`;
      }
      header.innerHTML = hHtml;
      panels.innerHTML = pHtml;
      for (let i = 0; i < numChildren; i++) renderChildPanel(i);
    }

    function switchChildTab(index) {
      activeChildTab = index;
      document.querySelectorAll('.child-tab-btn').forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });
      document.querySelectorAll('.child-panel').forEach((p, i) => {
        p.classList.toggle('active', i === index);
      });
    }

    function renderChildPanel(childIndex) {
      const panel = document.getElementById(`child-panel-${childIndex}`);
      if (!panel) return;
      const age = childAges[childIndex];
      const settings = childSettings[childIndex];
      let html = '';

      // 幼稚園〜高校
      for (let si = 0; si < 4; si++) {
        const stage = STAGES[si];
        const stageEnd = stage.deadlineAge + stage.years;
        const isPast = age !== null && age >= stageEnd;
        const isCurrent = age !== null && age >= stage.deadlineAge && age < stageEnd;
        const sel = settings[si];

        let badge = '';
        if (isPast) {
          badge = `<span class="stage-badge badge-past">終了</span>`;
        } else if (isCurrent) {
          badge = `<span class="stage-badge badge-current">在学中</span>`;
        } else if (age !== null) {
          const yrs = stage.deadlineAge - age;
          badge = `<span class="stage-badge badge-info">${yrs}年後〜</span>`;
        }

        html += `
          <div class="stage-row ${isPast ? 'past-stage' : ''}">
            <div class="stage-header">
              <span class="stage-name-text">${stage.name}</span>${badge}
            </div>
            <div class="stage-field">
              <div class="stage-field-label">学校の種別</div>
              <div class="btn-group">
                <button class="btn-opt btn-opt-sm ${sel.school === 'public' ? 'selected' : ''}"
                  onclick="setStage(${childIndex},${si},'school','public')">公立</button>
                <button class="btn-opt btn-opt-sm ${sel.school === 'private' ? 'selected' : ''}"
                  onclick="setStage(${childIndex},${si},'school','private')">私立</button>
              </div>
            </div>
            <div class="stage-field">
              <div class="stage-field-label">${stage.examLabel}</div>
              <div class="btn-group">
                <button class="btn-opt btn-opt-sm ${sel.exam === 'none' ? 'selected' : ''}"
                  onclick="setStage(${childIndex},${si},'exam','none')">なし</button>
                <button class="btn-opt btn-opt-sm ${sel.exam === 'standard' ? 'selected' : ''}"
                  onclick="setStage(${childIndex},${si},'exam','standard')">標準</button>
                <button class="btn-opt btn-opt-sm ${sel.exam === 'full' ? 'selected' : ''}"
                  onclick="setStage(${childIndex},${si},'exam','full')">しっかり</button>
              </div>
            </div>
          </div>`;
      }

      // 大学
      const univSel = settings[4];
      const univOpts = STAGES[4].options;
      const univPast = age !== null && age >= 22;
      const univCurrent = age !== null && age >= 18 && age < 22;
      let univBadge = '';
      if (univPast) {
        univBadge = `<span class="stage-badge badge-past">終了</span>`;
      } else if (univCurrent) {
        univBadge = `<span class="stage-badge badge-current">在学中</span>`;
      } else if (age !== null) {
        const yrs = 18 - age;
        if (yrs > 0) univBadge = `<span class="stage-badge badge-info">${yrs}年後〜</span>`;
      }

      html += `
        <div class="stage-row ${univPast ? 'past-stage' : ''}">
          <div class="stage-header">
            <span class="stage-name-text">大学・専門</span>${univBadge}
          </div>
          <div class="stage-field">
            <div class="stage-field-label">進路の種別</div>
            <div class="btn-group">
              ${Object.entries(univOpts).map(([key, opt]) =>
                `<button class="btn-opt btn-opt-sm ${univSel.school === key ? 'selected' : ''}"
                  onclick="setStage(${childIndex},4,'school','${key}')">${opt.label}</button>`
              ).join('')}
            </div>
          </div>
        </div>`;

      panel.innerHTML = html;
    }

    function setStage(childIndex, stageIndex, field, value) {
      childSettings[childIndex][stageIndex][field] = value;
      renderChildPanel(childIndex);
    }

    // ── 計算ロジック ──────────────────────────────────
    function getStageCostRaw(si, settings) {
      const stage = STAGES[si];
      if (si < 4) {
        const schoolAnnual = settings.school === 'public' ? stage.costs.public : stage.costs.private;
        const examCost = stage.examCosts[settings.exam] || 0;
        return schoolAnnual * stage.years + examCost;
      } else {
        const opt = stage.options[settings.school];
        if (!opt || opt.years === 0) return 0;
        return opt.annual * opt.years + opt.entrance;
      }
    }

    function getChildFutureCost(childIndex) {
      const age = childAges[childIndex];
      if (age === null) return 0;
      const settings = childSettings[childIndex];
      let total = 0;
      for (let si = 0; si < 5; si++) {
        const deadlineAge = STAGES[si].deadlineAge;
        if (age >= deadlineAge) continue;
        total += getStageCostRaw(si, settings[si]);
      }
      return total;
    }

    function calcPMT(monthlyRate, n, fv, pv) {
      if (n <= 0 || fv <= 0) return 0;
      if (monthlyRate === 0) return Math.max(0, (fv - pv) / n);
      const factor = Math.pow(1 + monthlyRate, n);
      return Math.max(0, (fv - pv * factor) * monthlyRate / (factor - 1));
    }

    // ステージごとのPMTを配列で返す（インデックス0=幼稚園〜4=大学）
    function calcStagePMTs(childIndex, monthlyRate, balance) {
      const age = childAges[childIndex];
      if (age === null) return [0, 0, 0, 0, 0];
      const settings = childSettings[childIndex];
      const pmts = [];
      let remaining = balance;

      for (let si = 0; si < 5; si++) {
        const deadlineAge = STAGES[si].deadlineAge;
        const months = (deadlineAge - age) * 12;
        if (months <= 0) { pmts.push(0); continue; }
        const cost = getStageCostRaw(si, settings[si]);
        if (cost <= 0) { pmts.push(0); continue; }

        const fvOfBalance = remaining > 0
          ? remaining * Math.pow(1 + monthlyRate, months)
          : 0;

        if (fvOfBalance >= cost) {
          const pvConsumed = monthlyRate > 0
            ? cost / Math.pow(1 + monthlyRate, months)
            : cost;
          remaining = Math.max(0, remaining - pvConsumed);
          pmts.push(0);
        } else {
          pmts.push(calcPMT(monthlyRate, months, cost, remaining));
          remaining = 0;
        }
      }
      return pmts;
    }

    function calcChildMonthly(childIndex, monthlyRate, balance) {
      return calcStagePMTs(childIndex, monthlyRate, balance).reduce((a, b) => a + b, 0);
    }

    // 積立スケジュール（期間ごとの合計月額）を返す
    function getChildSchedule(childIndex, stagePMTs) {
      const age = childAges[childIndex];
      if (age === null) return [];
      const currentYear = new Date().getFullYear();
      const deadlines = [3, 6, 12, 15, 18];
      const labels = ['幼稚園まで', '小学校まで', '中学まで', '高校まで', '大学まで'];
      const schedule = [];
      let prevAge = age;

      for (let di = 0; di < deadlines.length; di++) {
        const dAge = deadlines[di];
        if (dAge <= age) continue;

        // この期間に走っている積立 = deadline index di 以降のステージのPMT合計
        const periodMonthly = stagePMTs.slice(di).reduce((a, b) => a + b, 0);

        schedule.push({
          label: labels[di],
          fromAge: prevAge,
          toAge: dAge,
          startYear: currentYear + (prevAge - age),
          endYear: currentYear + (dAge - age) - 1,
          monthly: Math.round(periodMonthly * 10) / 10
        });
        prevAge = dAge;
      }
      return schedule;
    }

    // 年ごとの教育費支出（グラフ用）
    function getAnnualExpenses(childIndex) {
      const age = childAges[childIndex];
      const settings = childSettings[childIndex];
      const currentYear = new Date().getFullYear();
      const expenses = {};

      for (let si = 0; si < 4; si++) {
        const stage = STAGES[si];
        const schoolAnnual = settings[si].school === 'public' ? stage.costs.public : stage.costs.private;
        const examPerYear = (stage.examCosts[settings[si].exam] || 0) / stage.years;
        const annualCost = schoolAnnual + examPerYear;

        for (let a = stage.deadlineAge; a < stage.deadlineAge + stage.years; a++) {
          const yr = currentYear + (a - age);
          if (yr >= currentYear) {
            expenses[yr] = (expenses[yr] || 0) + annualCost;
          }
        }
      }

      const univOpt = STAGES[4].options[settings[4].school];
      if (univOpt && univOpt.years > 0) {
        const univStart = currentYear + (18 - age);
        for (let y = 0; y < univOpt.years; y++) {
          const yr = univStart + y;
          if (yr >= currentYear) {
            const cost = y === 0 ? univOpt.annual + univOpt.entrance : univOpt.annual;
            expenses[yr] = (expenses[yr] || 0) + cost;
          }
        }
      }

      return expenses;
    }

    function formatMan(v) {
      const rounded = Math.round(v * 10) / 10;
      return rounded.toLocaleString();
    }

    // ── メイン計算 ────────────────────────────────────
    function calculate() {
      for (let i = 0; i < numChildren; i++) {
        if (childAges[i] === null || isNaN(childAges[i])) {
          alert(`子ども${i + 1}の年齢を入力してください`);
          return;
        }
      }

      const currentBalance = parseFloat(document.getElementById('current-balance').value) || 0;
      const monthlySaving = parseFloat(document.getElementById('monthly-saving').value) || 0;
      const annualRate = parseFloat(document.getElementById('return-rate').value) / 100;
      const monthlyRate = annualRate / 12;

      // 子どもごとの将来教育費合計
      const futureCosts = Array.from({ length: numChildren }, (_, i) => getChildFutureCost(i));
      const grandTotal = futureCosts.reduce((a, b) => a + b, 0);

      // 現在残高を将来費用の比率で配分
      const childBalances = futureCosts.map(c =>
        grandTotal > 0 ? currentBalance * (c / grandTotal) : currentBalance / numChildren
      );

      // 子どもごとのステージ別PMTと合計
      const childStagePMTs = Array.from({ length: numChildren }, (_, i) =>
        calcStagePMTs(i, monthlyRate, childBalances[i])
      );
      const childPMTs = childStagePMTs.map(pmts => pmts.reduce((a, b) => a + b, 0));
      const totalRequired = childPMTs.reduce((a, b) => a + b, 0);
      const diff = monthlySaving - totalRequired;

      // ── 教育費の総額 ──
      document.getElementById('result-total-cost').innerHTML =
        `${formatMan(grandTotal)}<span>万円</span>`;

      // ── 内訳（子どもごと・ステージ別費用） ──
      const STAGE_LABELS = ['幼稚園', '小学校', '中学校', '高校', '大学・専門'];
      let breakdownHtml = '';
      for (let i = 0; i < numChildren; i++) {
        const age = childAges[i];
        const settings = childSettings[i];
        const childTotal = futureCosts[i];
        breakdownHtml += `<div class="breakdown-child-block">`;
        if (numChildren > 1) {
          breakdownHtml += `
            <div class="breakdown-child-label">
              <span class="child-dot" style="background:${CHILD_COLORS[i]}"></span>
              子ども${i + 1}（${age}歳）
              <span class="breakdown-child-total">${formatMan(Math.round(childTotal * 10) / 10)}万円</span>
            </div>`;
        }
        for (let si = 0; si < 5; si++) {
          const stage = STAGES[si];
          if (age >= stage.deadlineAge) continue;
          const cost = getStageCostRaw(si, settings[si]);
          if (cost <= 0) continue;
          let stageLabel = STAGE_LABELS[si];
          if (si < 4) {
            stageLabel += `（${settings[si].school === 'public' ? '公立' : '私立'}`;
            if (settings[si].exam !== 'none') {
              stageLabel += `・塾${settings[si].exam === 'standard' ? '標準' : 'しっかり'}`;
            }
            stageLabel += '）';
          } else {
            const opt = stage.options[settings[si].school];
            if (opt) stageLabel += `（${opt.label}）`;
          }
          breakdownHtml += `
            <div class="breakdown-row">
              <span class="breakdown-row-stage">${stageLabel}</span>
              <span class="breakdown-row-cost">${formatMan(Math.round(cost * 10) / 10)}万円</span>
            </div>`;
        }
        if (numChildren === 1) {
          breakdownHtml += `
            <div class="breakdown-total-row">
              <span>合計</span>
              <span>${formatMan(Math.round(childTotal * 10) / 10)}万円</span>
            </div>`;
        }
        breakdownHtml += `</div>`;
      }
      document.getElementById('result-breakdown').innerHTML = breakdownHtml;

      // ── 積立スケジュール表示 ──
      let scheduleHtml = '';
      for (let i = 0; i < numChildren; i++) {
        const sched = getChildSchedule(i, childStagePMTs[i]);
        if (sched.length === 0) continue;
        scheduleHtml += `<div class="schedule-child-block">`;
        if (numChildren > 1) {
          scheduleHtml += `<div class="schedule-child-label">
            <span class="child-dot" style="background:${CHILD_COLORS[i]};width:8px;height:8px;border-radius:50%;display:inline-block;"></span>
            子ども${i + 1}（${childAges[i]}歳）
          </div>`;
        }
        sched.forEach(row => {
          const yearRange = row.startYear === row.endYear
            ? `${row.startYear}年`
            : `${row.startYear}〜${row.endYear}年`;
          scheduleHtml += `
            <div class="schedule-row">
              <span class="schedule-row-period">${row.fromAge}歳〜${row.toAge}歳（${yearRange}）</span>
              <span class="schedule-row-amount">${row.monthly}万円/月</span>
            </div>`;
        });
        scheduleHtml += `</div>`;
      }
      document.getElementById('result-schedule').innerHTML = scheduleHtml;

      // ── グラフ ──
      const currentYear = new Date().getFullYear();
      const allExpenses = Array.from({ length: numChildren }, (_, i) => getAnnualExpenses(i));

      // 終了年 = 最後に教育費支出が発生する年（大学卒業の前年 = 在学最終年）
      let endYear = currentYear;
      for (let i = 0; i < numChildren; i++) {
        Object.keys(allExpenses[i]).forEach(y => {
          const yr = parseInt(y);
          if (allExpenses[i][yr] > 0 && yr > endYear) endYear = yr;
        });
      }

      // 積立停止年 = 末子が18歳になる前の年（PMT設計では18歳到達で全ステージ積立完了）
      const lastSavingYear = Math.max(
        ...Array.from({ length: numChildren }, (_, i) =>
          currentYear + Math.max(0, 18 - childAges[i]) - 1
        )
      );

      const years = [];
      for (let y = currentYear; y <= endYear; y++) years.push(y);

      // グラフ1：支出（子どもごとに積み上げ）
      const expenseDatasets = Array.from({ length: numChildren }, (_, i) => ({
        label: `子ども${i + 1}`,
        data: years.map(y => Math.round((allExpenses[i][y] || 0) * 10) / 10),
        backgroundColor: CHILD_COLORS[i],
        borderRadius: 3,
        stack: 'expenses'
      }));

      const expCtx = document.getElementById('expense-chart').getContext('2d');
      if (expenseChart) expenseChart.destroy();
      expenseChart = new Chart(expCtx, {
        type: 'bar',
        data: { labels: years.map(y => `${y}`), datasets: expenseDatasets },
        options: {
          responsive: true,
          plugins: {
            legend: {
              display: numChildren > 1,
              labels: { boxWidth: 10, font: { family: "'Noto Sans JP', sans-serif", size: 11 } }
            },
            tooltip: {
              callbacks: {
                label: ctx => ` ${ctx.dataset.label}：${ctx.raw}万円`
              }
            }
          },
          scales: {
            x: {
              stacked: true,
              ticks: { font: { family: "'Noto Sans JP', sans-serif", size: 10 } },
              grid: { display: false }
            },
            y: {
              stacked: true,
              beginAtZero: true,
              ticks: {
                callback: v => v + '万',
                font: { family: "'Noto Sans JP', sans-serif", size: 10 }
              },
              grid: { color: 'rgba(61,43,31,0.06)' }
            }
          }
        }
      });

      // グラフ2：残高推移
      // lastSavingYear の年まで積立を加算し、それ以降は積立なし（PMT設計通り）
      let balance = currentBalance;
      const balanceData = years.map(y => {
        const totalExpense = allExpenses.reduce((sum, exp) => sum + (exp[y] || 0), 0);
        const savingThisYear = y <= lastSavingYear ? monthlySaving * 12 : 0;
        balance = balance * (1 + annualRate) + savingThisYear - totalExpense;
        return Math.round(balance * 10) / 10;
      });

      const balCtx = document.getElementById('balance-chart').getContext('2d');
      if (balanceChart) balanceChart.destroy();
      balanceChart = new Chart(balCtx, {
        type: 'bar',
        data: {
          labels: years.map(y => `${y}`),
          datasets: [
            {
              label: '教育資金残高',
              data: balanceData,
              backgroundColor: balanceData.map(v => v < 0 ? '#e74c3c' : '#5B7C5F'),
              borderRadius: 3
            }
          ]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => ` 残高：${ctx.raw}万円`
              }
            }
          },
          scales: {
            x: {
              ticks: { font: { family: "'Noto Sans JP', sans-serif", size: 10 } },
              grid: { display: false }
            },
            y: {
              ticks: {
                callback: v => v + '万',
                font: { family: "'Noto Sans JP', sans-serif", size: 10 }
              },
              grid: { color: 'rgba(61,43,31,0.06)' }
            }
          }
        }
      });

      // ── アドバイス ──
      const negYears = years.filter((y, idx) => balanceData[idx] < 0);
      let advice;
      if (negYears.length === 0) {
        advice = `このペースで積み立てを続ければ、教育費の山を乗り越えられる見込みです。余裕がある時期は老後資金や住宅ローンの繰り上げ返済に回すのも一つの選択肢です。`;
      } else if (negYears[0] === currentYear) {
        const add = Math.round(Math.abs(diff) * 10) / 10;
        advice = `現状の積立では資金が不足する見込みです。月${add}万円ほど追加できると解消できます。まずは固定費の見直しや、学資保険・積立NISAの活用を検討してみましょう。`;
      } else {
        const add = Math.round(Math.abs(diff) * 10) / 10;
        advice = `${negYears[0]}年頃に資金が一時的に不足する見込みです。月${add}万円ほど積立額を増やすと解消できます。早めに手を打つほど複利の効果が大きくなります。`;
      }
      document.getElementById('prescription-text').textContent = advice;

      // ── Xシェア ──
      const childrenStr = Array.from({ length: numChildren }, (_, i) =>
        `子ども${i + 1}（${childAges[i]}歳）`
      ).join('・');
      const shareText = `教育費シミュレーション📚\n${childrenStr}の教育費総額：${formatMan(grandTotal)}万円\n必要な積立：月${formatMan(Math.round(totalRequired * 10) / 10)}万円\n\n#教育費 #資産形成 #らくらく夫婦\nhttps://life-works.net/kyoiku-hi/`;
      document.getElementById('share-btn').href =
        `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`;

      // ── 表示 ──
      const resultArea = document.getElementById('result-area');
      resultArea.classList.add('show');
      setTimeout(() => resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
    }

    // ── 初期化 ────────────────────────────────────────
    setNumChildren(1);
  </script>
</Base>
