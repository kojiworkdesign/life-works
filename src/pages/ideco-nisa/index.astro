---
// ideco-nisa/index.html から自動移行。本文・スクリプトは原文のまま。
import Base from '../../layouts/Base.astro';
import '../../styles/tools/ideco-nisa.css';
---

<Base
  title="iDeCo 診断ツール | らくらく夫婦ツール"
  description="年収・年齢・考え方を入力するだけ。iDeCoを始めるべきか、節税メリットはいくらか、何に投資すべきかが一括でわかります。"
  ogImage="/images/ideco-nisa.png"
>
<header class="header">
    <div class="header-inner">
      <a href="/" class="logo">らくらく夫婦<span>ツール</span></a>
    </div>
  </header>

  <div class="tool-wrap">

    <a href="/" class="back-link">← ツール一覧へ</a>

    <div class="tool-header">
      <p class="tool-eyebrow">投資・資産形成</p>
      <h1 class="tool-title">iDeCo<br>診断ツール</h1>
      <p class="tool-desc">あなたの条件と考え方から、iDeCoを始めるべきかを判定します。節税額・積立配分・投資スタイルまで一括でわかります。</p>
    </div>

    <!-- STEP1：基本条件 -->
    <div class="form-card">
      <p class="step-label">STEP 1 ／ あなたの基本条件</p>

      <div class="form-group">
        <label>現在の年齢</label>
        <div class="input-with-unit">
          <input type="number" id="age" placeholder="35" min="20" max="65">
          <span class="unit">歳</span>
        </div>
      </div>

      <div class="form-group">
        <label>職業区分</label>
        <div class="select-wrap">
          <select id="profession" onchange="updateIdecoLimit()">
            <option value="employee_no_pension">会社員（企業年金なし）</option>
            <option value="employee_dc">会社員（企業型DC加入中）</option>
            <option value="employee_db">会社員（確定給付年金DB加入中）</option>
            <option value="public">公務員</option>
            <option value="self_employed">自営業・フリーランス</option>
            <option value="homemaker">専業主婦（夫）</option>
          </select>
        </div>
        <div class="ideco-limit-hint">iDeCoの掛金上限：<strong id="limit-text">月2.3万円</strong></div>
      </div>

      <div class="form-group">
        <label>年収<span class="label-note">税引き前の額面年収</span></label>
        <div class="input-with-unit">
          <input type="number" id="income" placeholder="600" min="0" max="5000">
          <span class="unit">万円</span>
        </div>
      </div>

      <div class="form-group">
        <label>月々の積立余力<span class="label-note">iDeCo・NISAに回せる合計額</span></label>
        <div class="input-with-unit">
          <input type="number" id="monthly" placeholder="3" min="0.1" max="30" step="0.1">
          <span class="unit">万円</span>
        </div>
      </div>
    </div>

    <!-- STEP2：考え方 -->
    <div class="form-card">
      <p class="step-label">STEP 2 ／ あなたの考え方</p>

      <div class="form-group">
        <p class="q-label">Q1. 生活防衛資金（生活費3〜6ヶ月分）は確保できていますか？</p>
        <div class="choice-group" id="q1-group">
          <label class="choice-label" onclick="selectChoice('q1', 'ok', this)">
            <input type="radio" name="q1" value="ok">
            <span class="choice-text">確保済み（生活費3〜6ヶ月分以上ある）</span>
          </label>
          <label class="choice-label" onclick="selectChoice('q1', 'ng', this)">
            <input type="radio" name="q1" value="ng">
            <span class="choice-text">まだ確保できていない／不安</span>
          </label>
        </div>
      </div>

      <div class="form-group">
        <p class="q-label">Q2.「60歳まで絶対引き出せない」と聞いて、どう感じますか？</p>
        <div class="choice-group" id="q2-group">
          <label class="choice-label" onclick="selectChoice('q2', 'ok', this)">
            <input type="radio" name="q2" value="ok">
            <span class="choice-text">老後のためなら全然OK。むしろ強制的に貯まるのが助かる</span>
          </label>
          <label class="choice-label" onclick="selectChoice('q2', 'ng', this)">
            <input type="radio" name="q2" value="ng">
            <span class="choice-text">正直ちょっと不安。何かあったとき困るかも</span>
          </label>
        </div>
      </div>

      <div class="form-group">
        <p class="q-label">Q3. 投資に対するスタンスは？</p>
        <div class="choice-group" id="q3-group">
          <label class="choice-label" onclick="selectChoice('q3', 'aggressive', this)">
            <input type="radio" name="q3" value="aggressive">
            <span class="choice-text">多少の値下がりは気にしない。利益を最大化したい</span>
          </label>
          <label class="choice-label" onclick="selectChoice('q3', 'balanced', this)">
            <input type="radio" name="q3" value="balanced">
            <span class="choice-text">バランスよく、安定的に増やしたい</span>
          </label>
          <label class="choice-label" onclick="selectChoice('q3', 'conservative', this)">
            <input type="radio" name="q3" value="conservative">
            <span class="choice-text">なるべく元本を守りたい</span>
          </label>
        </div>
      </div>
    </div>

    <button class="btn-calc" onclick="calculate()">診断する</button>

    <!-- 結果エリア -->
    <div class="result-area" id="result-area">

      <!-- 推奨度 -->
      <div class="result-card" style="text-align:center;">
        <span class="verdict-badge" id="verdict-badge">判定</span>
        <p class="verdict-title" id="verdict-title">—</p>
        <p class="verdict-desc" id="verdict-desc">—</p>
      </div>

      <!-- 節税メリット -->
      <div class="result-card" id="savings-card">
        <p class="result-card-title">iDeCo の節税メリット</p>
        <div class="data-row">
          <span class="data-label">実効税率（所得税＋住民税）</span>
          <span class="data-value" id="tax-rate-text">—</span>
        </div>
        <div class="data-row">
          <span class="data-label">iDeCo有効掛金（月額）</span>
          <span class="data-value" id="effective-contribution">—</span>
        </div>
        <div class="data-row">
          <span class="data-label">年間節税額</span>
          <span class="data-value" id="annual-savings">—</span>
        </div>
        <div class="data-row">
          <span class="data-label">60歳までの累計節税額</span>
          <span class="data-value large" id="total-savings">—</span>
        </div>
      </div>

      <!-- 見送り時カード -->
      <div class="result-card" id="ng-card" style="display:none;">
        <p class="result-card-title">今やること</p>
        <p class="portfolio-type">生活防衛資金を貯める</p>
        <p class="portfolio-detail" id="ng-detail">—</p>
      </div>

      <!-- 積立配分 -->
      <div class="result-card" id="allocation-card">
        <p class="result-card-title">積立配分の提案</p>
        <div class="allocation-labels">
          <span><i class="dot" style="background:var(--color-primary)"></i>iDeCo</span>
          <span><i class="dot" style="background:#7aaa7f"></i>NISA</span>
        </div>
        <div class="allocation-bar-wrap">
          <div class="bar-ideco" id="bar-ideco" style="width:0%"></div>
          <div class="bar-nisa" id="bar-nisa" style="width:0%"></div>
        </div>
        <div class="allocation-amounts">
          <div class="allocation-item">
            <p class="allocation-item-label">iDeCo（月額）</p>
            <p class="allocation-item-value" id="alloc-ideco">—</p>
          </div>
          <div class="allocation-item">
            <p class="allocation-item-label">NISA（月額）</p>
            <p class="allocation-item-value" id="alloc-nisa">—</p>
          </div>
        </div>
        <p class="allocation-note" id="allocation-note">—</p>
      </div>

      <!-- ポートフォリオ提案 -->
      <div class="result-card" id="portfolio-card">
        <p class="result-card-title">iDeCo で選ぶ投資タイプ</p>
        <p class="portfolio-type" id="portfolio-type">—</p>
        <div class="portfolio-bar-wrap">
          <div class="pbar-stocks" id="pbar-stocks" style="width:0%"></div>
          <div class="pbar-bonds" id="pbar-bonds" style="width:0%"></div>
        </div>
        <p class="portfolio-detail" id="portfolio-detail">—</p>
      </div>

      <!-- Xシェア -->
      <a class="share-btn" id="share-btn" href="#" target="_blank">
        𝕏 結果をポストする
      </a>

      <!-- 注意事項 -->
      <div class="caution-card">
        <p class="caution-title">⚠️ 利用前に確認してほしいこと</p>
        <ul class="caution-list">
          <li>iDeCoは原則60歳まで引き出しできません。生活防衛資金（生活費3〜6ヶ月分）を確保してから始めましょう。</li>
          <li id="dc-caution" style="display:none;">企業型DC加入者は、会社の規約でiDeCo加入を制限している場合があります。人事・総務に確認してください。</li>
          <li>企業型DC・iDeCoと会社の退職金を同じ年に受け取ると、退職所得控除の枠を共有します。受取タイミングの分散を検討しましょう。</li>
          <li>本ツールの計算はあくまで目安です。詳細はFPまたは各金融機関にご相談ください。</li>
        </ul>
      </div>

      <!-- CTA -->
      <div class="brand-cta-section">
        <div class="brand-cta-header">
          <img src="/images/icon.png" alt="らくらく夫婦" class="brand-icon">
          <div>
            <p class="brand-cta-lead">らくらく夫婦と一緒に</p>
            <p class="brand-cta-title">お金の仕組みを、<br>夫婦でつくっていきませんか？</p>
          </div>
        </div>
        <p class="brand-cta-body">家計管理・資産形成のコツをLINEとnoteで発信中。まずは無料テンプレをLINEで受け取ってみてください。</p>
        <a href="https://lin.ee/Yzw8sE4" target="_blank" class="line-banner-link">
          <img src="/images/banner-line.png" alt="LINEで家計レントゲンシートを今すぐ受け取る">
        </a>
        <div class="cta-note">
          <div class="cta-note-text">
            <p class="cta-note-title">iDeCoの受取課税・退職金との関係</p>
            <p class="cta-note-desc">受取時の税金・退職所得控除の仕組みをnoteで詳しく解説。</p>
          </div>
          <a href="https://note.com/rakufu_log" target="_blank" class="btn-cta">読む →</a>
        </div>
      </div>

      <div class="affiliate-banner">
        <p class="affiliate-label">PR</p>
        <a href="https://px.a8.net/svt/ejp?a8mat=4B3R30+4M3YK2+3XCC+669JL" rel="nofollow">
          <img border="0" width="468" height="60" alt="松井証券" src="https://www27.a8.net/svt/bgt?aid=260515548279&wid=001&eno=01&mid=s00000018318001037000&mc=1">
        </a>
        <img border="0" width="1" height="1" src="https://www17.a8.net/0.gif?a8mat=4B3R30+4M3YK2+3XCC+669JL" alt="">
      </div>

    </div>
  </div>

  <footer class="footer">
    <p>© 2026 <a href="https://note.com/rakufu_log" target="_blank">らくらく夫婦</a> ｜ <a href="/">ツール一覧</a></p>
  </footer>

  

  <script is:inline>
    const IDECO_LIMITS = {
      employee_no_pension: 2.3,
      employee_dc: 2.0,
      employee_db: 1.2,
      public: 1.2,
      self_employed: 6.8,
      homemaker: 2.3,
    };

    const LIMIT_LABELS = {
      employee_no_pension: '月2.3万円',
      employee_dc: '月2.0万円',
      employee_db: '月1.2万円',
      public: '月1.2万円',
      self_employed: '月6.8万円',
      homemaker: '月2.3万円',
    };

    const answers = { q1: null, q2: null, q3: null };

    function selectChoice(q, value, el) {
      answers[q] = value;
      el.closest('.choice-group').querySelectorAll('.choice-label').forEach(l => l.classList.remove('selected'));
      el.classList.add('selected');
    }

    function updateIdecoLimit() {
      const prof = document.getElementById('profession').value;
      document.getElementById('limit-text').textContent = LIMIT_LABELS[prof];
    }

    function calcEmploymentDeduction(income) {
      if (income <= 162.5) return 55;
      if (income <= 180) return Math.max(income * 0.4 - 10, 55);
      if (income <= 360) return income * 0.3 + 8;
      if (income <= 660) return income * 0.2 + 44;
      if (income <= 850) return income * 0.1 + 110;
      return 195;
    }

    function calcEffectiveTaxRate(income) {
      const empDeduction = calcEmploymentDeduction(income);
      const socialInsurance = income * 0.15;
      const basicDeduction = 48;
      const taxableIncome = Math.max(income - empDeduction - socialInsurance - basicDeduction, 0);
      if (taxableIncome <= 195) return 0.15;
      if (taxableIncome <= 330) return 0.20;
      if (taxableIncome <= 695) return 0.30;
      if (taxableIncome <= 900) return 0.33;
      if (taxableIncome <= 1800) return 0.43;
      return 0.50;
    }

    function calcRetirementDeduction(years) {
      if (years <= 20) return 40 * years;
      return 800 + 70 * (years - 20);
    }

    function getPortfolio(age, riskStance) {
      if (riskStance === 'conservative') {
        return {
          type: '定期預金型 or 債券中心',
          stocks: 0,
          bonds: 100,
          detail: '元本確保型の定期預金商品や国内債券ファンドが中心。大きなリターンは期待しにくいですが、価値が下がりにくいのが特徴。老後資金の「守り」を重視したい方向けです。',
        };
      }
      if (age < 40) {
        // 39歳以下：運用期間20年以上
        return riskStance === 'aggressive'
          ? { type: '株式100%', stocks: 100, bonds: 0, detail: '全世界・国内インデックスファンド中心。運用期間が20年以上あり、複利の恩恵を最大化できます。短期の値動きは気にせず、長期で持ち続けましょう。' }
          : { type: '株式80%・債券20%', stocks: 80, bonds: 20, detail: '株式インデックス8割、債券2割の構成。成長を狙いながら安定性も確保。長期積立に適したバランスです。' };
      }
      if (age < 50) {
        // 40〜49歳：運用期間10〜20年
        return riskStance === 'aggressive'
          ? { type: '株式80%・債券20%', stocks: 80, bonds: 20, detail: '株式インデックス8割、債券2割の構成。まだ十分な運用期間がありますが、60歳受取を見据えて一部を安定資産へ。50代に入ったら株式比率の見直しも検討しましょう。' }
          : { type: '株式70%・債券30%', stocks: 70, bonds: 30, detail: '株式インデックス7割、債券3割のバランス型。安定と成長を両立しながら、受取に向けてリスクを少しずつ抑え始める時期です。' };
      }
      // 50歳以上：運用期間10年未満
      return riskStance === 'aggressive'
        ? { type: '株式70%・債券30%', stocks: 70, bonds: 30, detail: '受取まで10年前後。株式7割でまだ成長を狙いつつ、債券でダウンサイドを抑えます。60歳が近づいたら徐々に安定型へ移行しましょう。' }
        : { type: '株式50%・債券50%', stocks: 50, bonds: 50, detail: '株式と債券を半々にして安定性を高める時期です。受取前5年を目安に、さらに債券比率を高めることも視野に入れてください。' };
    }

    function calculate() {
      const age = parseInt(document.getElementById('age').value);
      const prof = document.getElementById('profession').value;
      const income = parseFloat(document.getElementById('income').value);
      const monthly = parseFloat(document.getElementById('monthly').value);

      if (!age || age < 20) return alert('年齢を入力してください');
      if (!income || income < 0) return alert('年収を入力してください');
      if (!monthly || monthly <= 0) return alert('月々の積立余力を入力してください');
      if (!answers.q1) return alert('Q1に回答してください');
      if (!answers.q2) return alert('Q2に回答してください');
      if (!answers.q3) return alert('Q3に回答してください');

      const idecoLimit = IDECO_LIMITS[prof];
      const yearsTo60 = Math.max(60 - age, 1);
      const taxRate = calcEffectiveTaxRate(income);
      const effectiveMonthly = Math.min(monthly, idecoLimit);
      const annualSavings = Math.round(effectiveMonthly * 12 * taxRate * 10) / 10;
      const totalSavings = Math.round(annualSavings * yearsTo60 * 10) / 10;
      const retirementDeduction = calcRetirementDeduction(yearsTo60);

      // 判定ロジック
      const taxMeaningful = taxRate >= 0.20;
      const liquidityOk = answers.q1 === 'ok' && answers.q2 === 'ok';

      let verdictKey, verdictBadgeText, verdictTitle, verdictDesc;

      if (answers.q1 === 'ng') {
        verdictKey = 'ng';
        verdictBadgeText = 'iDeCo：今は見送りを推奨';
        verdictTitle = 'まずは貯金を優先しましょう';
        verdictDesc = `iDeCoやNISAを始める前に、生活防衛資金（生活費3〜6ヶ月分）の確保が最優先です。万が一の備えがない状態で投資を始めると、緊急時に動かせるお金がなくなります。まず貯金を整えてから、投資のステップへ進みましょう。`;
      } else if (taxMeaningful && liquidityOk) {
        verdictKey = 'strong';
        verdictBadgeText = 'iDeCo：強くおすすめ';
        verdictTitle = 'iDeCoをぜひ始めましょう';
        verdictDesc = `年収${income}万円の場合、実効税率${Math.round(taxRate * 100)}%。iDeCoで年間${annualSavings.toFixed(1)}万円の節税になります。60歳までの累計では${totalSavings.toFixed(0)}万円お得になる計算です。条件もそろっているので、まずiDeCoを上限まで使い、残りをNISAへ回す二刀流が最適です。`;
      } else {
        verdictKey = 'limited';
        verdictBadgeText = 'iDeCo：条件付きでおすすめ';
        verdictTitle = '状況に合わせて検討しましょう';
        if (!taxMeaningful && liquidityOk) {
          verdictDesc = `年収${income}万円の場合、節税メリットは年間${annualSavings.toFixed(1)}万円と限定的です。NISAの方が流動性も高く使いやすいので、まずNISAを優先し、iDeCoは余力で検討するのがよいでしょう。`;
        } else {
          verdictDesc = `節税メリットはあります（年間${annualSavings.toFixed(1)}万円）が、生活防衛資金の確保または引き出し制限への準備を先に整えることをおすすめします。準備が整えば、iDeCoは強力な節税手段になります。`;
        }
      }

      // 配分提案
      let idecoAlloc, nisaAlloc, allocNote;
      if (verdictKey === 'ng') {
        idecoAlloc = 0;
        nisaAlloc = 0;
        allocNote = '';
      } else {
        idecoAlloc = effectiveMonthly;
        nisaAlloc = Math.max(monthly - idecoLimit, 0);
        if (monthly <= idecoLimit) {
          allocNote = verdictKey === 'strong'
            ? `全額iDeCoへ。積立余力が上限以内なのでiDeCoに集中できます。`
            : `条件が整えばiDeCoへ全額。まずは準備を整えましょう。`;
        } else {
          allocNote = `iDeCoを上限（月${idecoLimit}万円）まで使い、残りの月${nisaAlloc.toFixed(1)}万円はNISAへ。二刀流が最適です。`;
        }
      }

      const idecoPercent = monthly > 0 ? Math.round((idecoAlloc / monthly) * 100) : 0;
      const nisaPercent = 100 - idecoPercent;

      // ポートフォリオ
      const portfolio = getPortfolio(age, answers.q3);

      // --- 表示 ---
      const badge = document.getElementById('verdict-badge');
      badge.textContent = verdictBadgeText;
      badge.className = `verdict-badge ${verdictKey}`;
      document.getElementById('verdict-title').textContent = verdictTitle;
      document.getElementById('verdict-desc').textContent = verdictDesc;

      document.getElementById('tax-rate-text').textContent = `${Math.round(taxRate * 100)}%`;
      document.getElementById('effective-contribution').textContent = `月${effectiveMonthly}万円`;
      document.getElementById('annual-savings').textContent = `${annualSavings.toFixed(1)}万円`;
      document.getElementById('total-savings').textContent = `${totalSavings.toFixed(0)}万円`;

      document.getElementById('bar-ideco').style.width = `${idecoPercent}%`;
      document.getElementById('bar-nisa').style.width = `${nisaPercent}%`;
      document.getElementById('alloc-ideco').textContent = `月${idecoAlloc.toFixed(1)}万円`;
      document.getElementById('alloc-nisa').textContent = `月${nisaAlloc.toFixed(1)}万円`;
      document.getElementById('allocation-note').textContent = allocNote;

      document.getElementById('portfolio-type').textContent = portfolio.type;
      document.getElementById('pbar-stocks').style.width = `${portfolio.stocks}%`;
      document.getElementById('pbar-bonds').style.width = `${portfolio.bonds}%`;
      document.getElementById('pbar-stocks').textContent = portfolio.stocks > 15 ? `株式${portfolio.stocks}%` : '';
      document.getElementById('pbar-bonds').textContent = portfolio.bonds > 15 ? `債券${portfolio.bonds}%` : '';
      document.getElementById('portfolio-detail').textContent = portfolio.detail;

      // 見送り/通常の表示切り替え
      const isNg = verdictKey === 'ng';
      document.getElementById('ng-card').style.display = isNg ? 'block' : 'none';
      document.getElementById('allocation-card').style.display = isNg ? 'none' : 'block';
      document.getElementById('portfolio-card').style.display = isNg ? 'none' : 'block';

      if (isNg) {
        document.getElementById('ng-detail').textContent = `毎月の積立余力（月${monthly}万円）は、まず生活費3〜6ヶ月分の貯金に充てましょう。目安は生活費×3〜6ヶ月分。貯金が整ったら、NISAやiDeCoを始める準備が整います。`;
      }

      // DC注意
      document.getElementById('dc-caution').style.display = prof === 'employee_dc' ? 'list-item' : 'none';

      // Xシェア
      const verdictShort = verdictKey === 'strong' ? '強くおすすめ' : verdictKey === 'limited' ? '条件付きでおすすめ' : '今は見送りを推奨';
      const shareText = `iDeCo診断やってみた📊\n結果：${verdictShort}\n年収${income}万円なら年間${annualSavings.toFixed(1)}万円の節税💡\n60歳まで累計${totalSavings.toFixed(0)}万円お得になる計算\n\n#iDeCo #NISA #資産形成 #らくらく夫婦\nhttps://life-works.net/ideco-nisa/`;
      document.getElementById('share-btn').href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`;

      const resultArea = document.getElementById('result-area');
      resultArea.classList.add('show');
      setTimeout(() => resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
    }
  </script>
