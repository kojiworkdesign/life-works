---
// kakeibo-shindan/index.html から自動移行。本文・スクリプトは原文のまま。
import Base from '../../layouts/Base.astro';
import '../../styles/tools/kakeibo-shindan.css';
---

<Base
  title="お金グセ命名診断 | らくらく夫婦ツール"
  description="10問に答えるだけ。AIがあなただけのお金グセ命名をします。夫婦あるある・お金の価値観まで丸裸に。"
  ogImage="/images/card-kakeibo-shindan.png"
>
<header class="header">
    <div class="header-inner">
      <a href="/" class="logo">らくらく夫婦<span>ツール</span></a>
    </div>
  </header>

  <div class="tool-wrap">

    <a href="/" class="page-back-link">← ツール一覧へ</a>

    <div class="tool-header" id="tool-header">
      <p class="tool-eyebrow">夫婦のお金・家計</p>
      <h1 class="tool-title">お金グセ命名診断</h1>
      <p class="tool-desc">10問に答えるだけ。AIがあなただけのお金グセ命名をします。<br>夫婦あるある・お金の価値観まで丸裸に。</p>
    </div>

    <div class="progress-wrap" id="progress-wrap" style="display:none;">
      <div class="progress-meta">
        <span id="progress-label">Q1 / 10</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-bar-bg">
        <div class="progress-bar-fill" id="progress-fill" style="width:0%"></div>
      </div>
    </div>

    <div id="back-btn-area" style="display:none;">
      <button class="back-btn" onclick="goBack()">← 前の質問に戻る</button>
    </div>

    <div id="question-area"></div>

    <div id="start-area" style="text-align:center;">
      <button class="btn-next" onclick="showBasicInfo()">診断スタート →</button>
    </div>

    <div class="loading-area" id="loading-area">
      <div class="loading-spinner"></div>
      <p class="loading-text">あなたのお金グセを命名中…</p>
      <p class="loading-sub">AIがあなただけの名前を考えています</p>
    </div>

    <div class="result-area" id="result-area">
      <div class="result-type-card">
        <p class="result-eyebrow">あなたのお金グセ</p>
        <p class="result-type-name" id="result-type-name">—</p>
        <p class="result-subtitle" id="result-subtitle">—</p>
        <hr class="result-divider">
        <p class="result-desc" id="result-desc">—</p>
      </div>

      <div class="result-advice-card">
        <p class="result-advice-label">らくらく夫婦より</p>
        <p class="result-advice-text" id="result-advice">—</p>
      </div>

      <a class="share-btn" id="share-btn" href="#" target="_blank">
        𝕏 命名結果をポストする
      </a>

      <button class="retry-btn" onclick="resetDiagnosis()">もう一度診断する</button>

      <div class="brand-cta-section">
        <div class="brand-cta-header">
          <img src="/images/icon.png" alt="らくらく夫婦" class="brand-icon">
          <div>
            <p class="brand-cta-lead">らくらく夫婦と一緒に</p>
            <p class="brand-cta-title">お金の仕組みを、<br>夫婦でつくっていきませんか？</p>
          </div>
        </div>
        <p class="brand-cta-body">家計管理・資産形成のコツをLINEとnoteで発信中。まずは無料テンプレをLINEで受け取ってみてください。</p>
        <a href="https://lin.ee/Yzw8sE4" target="_blank" class="line-banner-link">
          <img src="/images/banner-line.png" alt="LINEで家計レントゲンシートを今すぐ受け取る">
        </a>
      </div>

      <div class="affiliate-banner">
        <p class="affiliate-label">PR</p>
        <a href="https://px.a8.net/svt/ejp?a8mat=4B3R30+4M3YK2+3XCC+669JL" rel="nofollow">
          <img border="0" width="468" height="60" alt="松井証券" src="https://www27.a8.net/svt/bgt?aid=260515548279&wid=001&eno=01&mid=s00000018318001037000&mc=1">
        </a>
        <img border="0" width="1" height="1" src="https://www17.a8.net/0.gif?a8mat=4B3R30+4M3YK2+3XCC+669JL" alt="">
      </div>

    </div>

  </div>

  <footer class="footer">
    <p>© 2026 <a href="https://note.com/rakufu_log" target="_blank">らくらく夫婦</a> ｜ <a href="/">ツール一覧</a></p>
  </footer>

  

  <script is:inline>
    const QUESTIONS = {
      q1: {
        text: '毎月いくら貯金できてるか、ちゃんとわかる？',
        options: [
          { value: 'A', label: '把握してる、管理してる' },
          { value: 'B', label: 'なんとなくわかる' },
          { value: 'C', label: '正直わからない' },
        ],
        next: () => 'q2',
      },
      q2: {
        text: '家計管理、どっちがやってる？',
        options: [
          { value: 'A', label: '自分がメインでやってる' },
          { value: 'B', label: 'パートナーがメインでやってる' },
          { value: 'C', label: 'なんとなくお互いざっくり' },
        ],
        next: () => 'q3',
      },
      q3: {
        text: '「今月使いすぎたかも」と気づくのはいつ？',
        options: [
          { value: 'A', label: '予算と照らし合わせてこまめにチェックしてる' },
          { value: 'B', label: '残高や明細を見てようやく気づく' },
          { value: 'C', label: '翌月になってから（もしくは気づかない）' },
        ],
        next: () => 'q4',
      },
      q4: {
        text: '投資・NISA・iDeCoはやってる？',
        options: [
          { value: 'A', label: 'がっつりやってる' },
          { value: 'B', label: '少しだけやってる' },
          { value: 'C', label: 'まだやってない' },
        ],
        next: (val) => val === 'C' ? 'q5b' : 'q5a',
      },
      q5a: {
        text: '主にどんな投資をしてる？',
        options: [
          { value: 'A', label: 'インデックスファンド中心（オルカン・S&P500など）' },
          { value: 'B', label: '個別株・ETF中心（国内外問わず）' },
          { value: 'C', label: '仮想通貨・FXなどハイリスク系も含む' },
          { value: 'D', label: '債券・金・バランス型など安定系も組み合わせてる' },
        ],
        next: () => 'q6a',
      },
      q6a: {
        text: '投資をしている一番の理由は？',
        options: [
          { value: 'A', label: '老後資金をコツコツ増やしたい' },
          { value: 'B', label: '資産を守りながら少しずつ増やしたい（インフレ対策）' },
          { value: 'C', label: '早期リタイア・FIREを本気で目指してる' },
          { value: 'D', label: 'みんなやってるし、とりあえずやらないとと思って' },
          { value: 'E', label: '正直、もっと稼いでいい暮らしがしたい' },
        ],
        next: () => 'q7a',
      },
      q7a: {
        text: 'SNSでお金・投資の情報、どう付き合ってる？',
        options: [
          { value: 'A', label: '自分も発信してる。フォロワーに役立てたい' },
          { value: 'B', label: '見るのは好きだけど自分は発信しない' },
          { value: 'C', label: '参考にしてるけど、資産報告やマウント投稿にモヤっとすることもある' },
          { value: 'D', label: '情報収集が趣味になってる。でも行動はまだこれから' },
          { value: 'E', label: 'SNSでお金の情報はほぼ見ていない' },
        ],
        next: () => 'q8a',
      },
      q8a: {
        text: 'FIREについて、どう思う？',
        options: [
          { value: 'A', label: 'FIRE？なにそれ（知らなかった）' },
          { value: 'B', label: '憧れるけど、現実的にはどうかな' },
          { value: 'C', label: '本気で計画中。数字も追ってる' },
          { value: 'D', label: 'すでにFIRE・セミFIREしてる' },
        ],
        next: () => 'q9',
      },
      q5b: {
        text: '投資に踏み出せない理由は？',
        options: [
          { value: 'A', label: '怖い・難しそう・よくわからない' },
          { value: 'B', label: '家計に余裕がなくて後回しになってる' },
          { value: 'C', label: '必要性をあまり感じていない' },
        ],
        next: () => 'q6b',
      },
      q6b: {
        text: '老後のお金、どのくらいリアルに考えてる？',
        options: [
          { value: 'A', label: 'なんかしなきゃと思いつつ、まだぼんやりしてる' },
          { value: 'B', label: '考えるのが怖くて正直見ないようにしてる' },
          { value: 'C', label: 'まだ先すぎてピンとこない' },
        ],
        next: () => 'q9',
      },
      q9: {
        text: 'パートナーとのお金の温度差、ある？',
        options: [
          { value: 'A', label: '自分の方が断然関心が高い。温度差がつらい' },
          { value: 'B', label: 'パートナーの方が積極的で、ついていくのがやっと' },
          { value: 'C', label: '同じくらい関心があって、よく話し合えてる' },
          { value: 'D', label: 'お金の話自体があまりできていない' },
        ],
        next: () => 'q10',
      },
      q10: {
        text: '旅行・家電など大きな出費はどう乗り越えてる？',
        options: [
          { value: 'A', label: '特別費として毎月積み立ててるから余裕' },
          { value: 'B', label: 'ボーナスで何とかする作戦' },
          { value: 'C', label: 'カードで払ってなんとかなってる' },
          { value: 'D', label: '毎回オーバーして後悔してる。でも懲りない' },
          { value: 'E', label: '貯金や投資を切り崩して対応してる' },
        ],
        next: () => null,
      },
    };

    let currentId = null;
    let history = [];
    let answers = [];
    let stepCount = 0;
    let totalSteps = 10;
    let basicInfo = { role: null, age: null };
    let freeComment = '';

    function showBasicInfo() {
      document.getElementById('start-area').style.display = 'none';
      document.getElementById('tool-header').style.display = 'none';

      document.getElementById('question-area').innerHTML = `
        <div class="question-card">
          <p class="question-text">まず、あなたのことを教えてください</p>
          <div class="info-group">
            <span class="info-label">あなたは？</span>
            <div class="choice-group" id="role-group">
              <button class="choice-btn" onclick="selectRole('妻（既婚・女性）', this)">妻（既婚・女性）</button>
              <button class="choice-btn" onclick="selectRole('夫（既婚・男性）', this)">夫（既婚・男性）</button>
              <button class="choice-btn" onclick="selectRole('独り身の女性', this)">独り身の女性</button>
              <button class="choice-btn" onclick="selectRole('独り身の男性', this)">独り身の男性</button>
            </div>
          </div>
          <div class="info-group">
            <span class="info-label">年齢</span>
            <div class="input-with-unit">
              <input type="number" id="age-input" placeholder="35" min="18" max="80">
              <span class="unit">歳</span>
            </div>
          </div>
          <button class="btn-next" onclick="submitBasicInfo()">診断スタート →</button>
        </div>
      `;
    }

    function selectRole(role, btn) {
      document.querySelectorAll('#role-group .choice-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      basicInfo.role = role;
    }

    function submitBasicInfo() {
      const age = parseInt(document.getElementById('age-input').value);
      if (!basicInfo.role) return alert('あなたの立場を選んでください');
      if (!age || age < 18 || age > 80) return alert('年齢を入力してください（18〜80歳）');
      basicInfo.age = age;

      currentId = 'q1';
      history = [];
      answers = [];
      stepCount = 0;

      document.getElementById('progress-wrap').style.display = 'block';
      showQuestion('q1');
    }

    function showQuestion(id) {
      const q = QUESTIONS[id];
      stepCount++;
      updateProgress();

      document.getElementById('back-btn-area').style.display = history.length > 0 ? 'block' : 'none';

      document.getElementById('question-area').innerHTML = `
        <div class="question-card">
          <p class="question-text">${q.text}</p>
          <div class="choice-group">
            ${q.options.map(opt => `
              <button class="choice-btn" onclick="selectAnswer('${id}', '${opt.value}', '${escapeJs(opt.label)}', this)">
                ${opt.label}
              </button>
            `).join('')}
          </div>
        </div>
      `;
    }

    function showFreeComment() {
      document.getElementById('back-btn-area').style.display = 'block';
      document.getElementById('question-area').innerHTML = `
        <div class="question-card">
          <p class="question-text">最後に、ひとことどうぞ（任意）</p>
          <p class="free-comment-note">家計のあるあるやお金の悩みを自由に書いてね。AIがより的確な命名をします。</p>
          <textarea
            id="free-comment-input"
            class="free-comment-textarea"
            placeholder="例：夫がお金の話を嫌がる、貯金はあるのに投資が怖い…など"
            maxlength="100"
            oninput="updateCharCount(this)"
          ></textarea>
          <p class="char-count" id="char-count">0 / 100</p>
          <button class="btn-next" onclick="submitWithComment()" style="margin-top:8px;">命名してもらう →</button>
        </div>
      `;
    }

    function updateCharCount(el) {
      document.getElementById('char-count').textContent = `${el.value.length} / 100`;
    }

    function submitWithComment() {
      freeComment = document.getElementById('free-comment-input')?.value?.trim() || '';
      submitDiagnosis();
    }

    function escapeJs(str) {
      return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
    }

    function updateProgress() {
      const q4answer = answers.find(a => a.qId === 'q4');
      totalSteps = (q4answer && q4answer.value === 'C') ? 8 : 10;
      const pct = Math.round(((stepCount - 1) / totalSteps) * 100);
      document.getElementById('progress-label').textContent = `Q${stepCount} / ${totalSteps}`;
      document.getElementById('progress-pct').textContent = `${pct}%`;
      document.getElementById('progress-fill').style.width = `${pct}%`;
    }

    function selectAnswer(qId, value, label, btn) {
      btn.closest('.choice-group').querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      const q = QUESTIONS[qId];
      answers.push({ qId, value, question: q.text, answer: label });
      history.push(qId);

      const nextId = q.next(value);
      setTimeout(() => {
        if (nextId) {
          currentId = nextId;
          showQuestion(nextId);
        } else {
          showFreeComment();
        }
      }, 280);
    }

    function goBack() {
      if (history.length === 0) return;
      answers.pop();
      const prevId = history.pop();
      stepCount -= 2;
      currentId = prevId;
      document.getElementById('back-btn-area').style.display = history.length > 0 ? 'block' : 'none';
      showQuestion(prevId);
    }

    async function submitDiagnosis() {
      document.getElementById('question-area').style.display = 'none';
      document.getElementById('back-btn-area').style.display = 'none';
      document.getElementById('progress-wrap').style.display = 'none';
      document.getElementById('loading-area').classList.add('show');

      try {
        const res = await fetch('/api/kakeibo-shindan/diagnose', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            answers: answers.map(a => ({ question: a.question, answer: a.answer })),
            basicInfo,
            freeComment,
          }),
        });

        if (!res.ok) throw new Error(`API error: ${res.status}`);
        const data = await res.json();
        showResult(data);
      } catch (err) {
        console.error(err);
        document.getElementById('loading-area').classList.remove('show');
        document.getElementById('question-area').style.display = 'block';
        document.getElementById('question-area').innerHTML = `
          <div class="question-card" style="text-align:center;">
            <p style="font-size:0.95rem;color:var(--color-text-muted);line-height:1.8;">
              診断中にエラーが発生しました。<br>もう一度お試しください。
            </p>
            <button class="btn-next" onclick="resetDiagnosis()" style="margin-top:20px;">
              最初からやり直す
            </button>
          </div>
        `;
      }
    }

    function showResult(data) {
      document.getElementById('loading-area').classList.remove('show');
      document.getElementById('result-type-name').textContent = data.type_name;
      document.getElementById('result-subtitle').textContent = data.subtitle;
      document.getElementById('result-desc').textContent = data.description;
      document.getElementById('result-advice').textContent = data.advice;

      const shareText = `わたしのお金グセは「${data.type_name}」でした😂\n${data.subtitle}\n\n#お金グセ命名診断 #らくらく夫婦\nhttps://life-works.net/kakeibo-shindan/`;
      document.getElementById('share-btn').href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`;

      const resultArea = document.getElementById('result-area');
      resultArea.classList.add('show');
      setTimeout(() => resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
    }

    function resetDiagnosis() {
      currentId = null;
      history = [];
      answers = [];
      stepCount = 0;
      basicInfo = { role: null, age: null };
      freeComment = '';

      document.getElementById('result-area').classList.remove('show');
      document.getElementById('loading-area').classList.remove('show');
      document.getElementById('question-area').style.display = 'block';
      document.getElementById('question-area').innerHTML = '';
      document.getElementById('back-btn-area').style.display = 'none';
      document.getElementById('tool-header').style.display = 'block';
      document.getElementById('start-area').style.display = 'block';
      document.getElementById('progress-wrap').style.display = 'none';

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</Base>
